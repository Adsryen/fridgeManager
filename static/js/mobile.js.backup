// ==================== 日期快捷按钮功能 ====================

// 格式化日期显�?
function formatDateDisplay(dateString) {
    if (!dateString) return '点击选择日期';
    
    const date = new Date(dateString);
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    
    return `${year}�?{month}�?{day}日`;
}

// 设置日期快捷方式
window.setDateShortcut = function(formType, days) {
    const today = new Date();
    const targetDate = new Date(today);
    targetDate.setDate(today.getDate() + days);
    
    // 格式化为 YYYY-MM-DD
    const year = targetDate.getFullYear();
    const month = String(targetDate.getMonth() + 1).padStart(2, '0');
    const day = String(targetDate.getDate()).padStart(2, '0');
    const dateString = `${year}-${month}-${day}`;
    
    // 根据表单类型设置对应的日期输入框
    if (formType === 'add') {
        $('#addItemDate').val(dateString);
        $('#addItemDateDisplay').text(formatDateDisplay(dateString)).addClass('has-value');
    } else if (formType === 'edit') {
        $('#editItemDate').val(dateString);
        $('#editItemDateDisplay').text(formatDateDisplay(dateString)).addClass('has-value');
    }
    
    showToast(`已设置为${days}天后`, 'success');
}

// 监听日期输入框的变化
$(document).on('change', '#addItemDate', function() {
    const dateValue = $(this).val();
    $('#addItemDateDisplay').text(formatDateDisplay(dateValue)).addClass('has-value');
});

$(document).on('change', '#editItemDate', function() {
    const dateValue = $(this).val();
    $('#editItemDateDisplay').text(formatDateDisplay(dateValue)).addClass('has-value');
});

// 导出数据
window.exportData = function() {
    const dataStr = JSON.stringify(allItems, null, 2);
    const dataBlob = new Blob([dataStr], {type: 'application/json'});
    const url = URL.createObjectURL(dataBlob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `fridge-data-${moment().format('YYYY-MM-DD')}.json`;
    link.click();
    showToast('数据已导�?, 'success');
}

// 清理已过期物�?
window.clearExpiredItems = function() {
    const now = moment();
    const expiredItems = allItems.filter(item => {
        return moment(item.ExpireDate).diff(now, 'days') < 0;
    });
    
    if (expiredItems.length === 0) {
        showToast('没有已过期的物品', 'info');
        return;
    }
    
    if (!confirm(`确定要删�?${expiredItems.length} 个已过期物品吗？`)) {
        return;
    }
    
    let deleted = 0;
    expiredItems.forEach(item => {
        $.ajax({
            type: 'POST',
            url: '/item/delete/' + item._id,
            success: function() {
                deleted++;
                if (deleted === expiredItems.length) {
                    showToast(`已清�?${deleted} 个过期物品`, 'success');
                    loadAllItems();
                }
            }
        });
    });
}


