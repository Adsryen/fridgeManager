});


// ==================== 页面切换功能 ====================

// 切换视图
window.switchView = function(view) {
    console.log('切换到视�?', view);
    
    // 更新底部导航�?
    $('.nav-item').removeClass('active');
    $(`.nav-item[data-view="${view}"]`).addClass('active');
    
    // 隐藏所有页�?
    $('.mobile-content').hide();
    $('.page-view').hide();
    
    // 控制分类横向栏的显示/隐藏
    if (view === 'home') {
        $('.category-tags-container').show();
        $('.mobile-content').show();
    } else if (view === 'category') {
        $('.category-tags-container').hide();
        $('#categoryPage').show();
        updateCategoryCounts();
    } else if (view === 'stats') {
        $('.category-tags-container').hide();
        $('#statsPage').show();
        updateStatsPage();
    } else if (view === 'settings') {
        $('.category-tags-container').hide();
        $('#settingsPage').show();
        updateSettingsPage();
    }
}

// ==================== 分类页面功能 ====================

// 更新分类计数
function updateCategoryCounts() {
    const categoryCounts = { all: allItems.length };
    
    allItems.forEach(item => {
        const types = item.Type.split(',');
        types.forEach(type => {
            const t = type.trim();
            categoryCounts[t] = (categoryCounts[t] || 0) + 1;
        });
    });
    
    // 更新分类页面的计�?
    Object.keys(categoryCounts).forEach(type => {
        const capitalizedType = type.charAt(0).toUpperCase() + type.slice(1);
        $(`#cat${capitalizedType}Count`).text(categoryCounts[type] || 0);
    });
    
    // 更新横向标签的计�?
    const allCount = categoryCounts.all || 0;
    const tagAllCount = $('#tagAllCount');
    tagAllCount.text(allCount);
    if (allCount === 0) {
        tagAllCount.hide();
    } else {
        tagAllCount.show();
    }
    
    const allTypes = ['vegetable', 'fruit', 'meat', 'seafood', 'diary', 'beverage', 'egg', 'bread', 'frozen', 'sauce', 'snack', 'other'];
    allTypes.forEach(type => {
        const capitalizedType = type.charAt(0).toUpperCase() + type.slice(1);
        const count = categoryCounts[type] || 0;
        const countElement = $(`#tag${capitalizedType}Count`);
        countElement.text(count);
        // 如果数量�?，隐藏气�?
        if (count === 0) {
            countElement.hide();
        } else {
            countElement.show();
        }
    });
}

// 按类别筛选（用于横向标签�?
window.filterByCategory = function(category) {
    console.log('按类别筛�?', category);
    
    // 更新标签选中状�?
    $('.category-tag').removeClass('active');
    $(`.category-tag[data-type="${category}"]`).addClass('active');
    
    // 重置位置筛�?
    currentPlace = 'all';
    $('.sidebar-item').removeClass('active');
    $('.sidebar-item[data-place="all"]').addClass('active');
    
    if (category === 'all') {
        // 显示所有物�?
        displayItems(allItems);
    } else {
        // 筛选该类别的物�?
        const filtered = allItems.filter(item => {
            const types = item.Type.split(',').map(t => t.trim());
            return types.includes(category);
        });
        displayItems(filtered);
    }
}

// 显示分类物品列表（使用相同的卡片样式�?
function displayCategoryItems(items) {
    const container = $('#categoryItemsList');
    
    if (items.length === 0) {
        container.html(`
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <h4>暂无物品</h4>
                <p>该类别下还没有物�?/p>
            </div>
        `);
        return;
    }
    
    const now = moment();
    let html = '';
    
    items.forEach(item => {
        const expireDate = moment(item.ExpireDate);
        const daysUntilExpire = expireDate.diff(now, 'days');
        
        let statusClass = '';
        let statusText = '';
        let statusBadgeClass = '';
        
        if (daysUntilExpire < 0) {
            statusClass = 'expired';
            statusText = `${Math.abs(daysUntilExpire)}天`;
            statusBadgeClass = 'danger';
        } else if (daysUntilExpire === 0) {
            statusClass = 'expiring-soon';
            statusText = '今天';
            statusBadgeClass = 'danger';
        } else if (daysUntilExpire <= expiryWarningDays) {
            statusClass = 'expiring-soon';
            statusText = `${daysUntilExpire}天`;
            statusBadgeClass = 'warning';
        } else {
            statusText = `${daysUntilExpire}天`;
            statusBadgeClass = 'fresh';
        }
        
        const emoji = getTypeEmoji(item.Type);
        const placeText = getPlaceText(item.Place);
        
        html += `
            <div class="mobile-item-card ${statusClass}">
                <div class="item-card-main">
                    <div class="item-card-header">
                        <div class="item-emoji">${emoji}</div>
                        <div class="item-name-info">
                            <h3>${item.Name}</h3>
                            <span class="item-place-badge clickable" onclick="event.stopPropagation(); filterByPlace('${item.Place}'); switchView('home');" title="点击筛�?{placeText}">
                                <i class="fas fa-map-marker-alt"></i>
                                ${placeText}
                            </span>
                        </div>
                    </div>
                    <div class="item-card-body">
                        <div class="item-info-row">
                            <i class="fas fa-calendar-alt"></i>
                            <span>${expireDate.format('MM-DD')}</span>
                        </div>
                        <div class="item-info-row">
                            <i class="fas fa-boxes"></i>
                            <span>×${item.Num}</span>
                        </div>
                        <div class="item-expiry-status ${statusBadgeClass}">
                            <span>${statusText}</span>
                        </div>
                    </div>
                </div>
                <div class="item-card-actions">
                    <button class="item-action-btn edit" onclick="editItem('${item._id}')" title="编辑">
                        <i class="fas fa-edit"></i>
                    </button>
                    <button class="item-action-btn delete" onclick="deleteItem('${item._id}', '${item.Name}')" title="删除">
                        <i class="fas fa-trash"></i>
                    </button>
                </div>
            </div>
        `;
    });
    
    container.html(html);
}

// 按类别筛选（旧函数，保留兼容性）
window.showCategoryItems = function(category) {
    console.log('显示分类物品:', category);
    
    // 筛选该类别的物�?
    const filtered = allItems.filter(item => {
        const types = item.Type.split(',').map(t => t.trim());
        return types.includes(category);
    });
    
    // 获取类别信息
    const categoryInfo = {
        vegetable: { emoji: '🥬', name: '蔬菜' },
        fruit: { emoji: '🍎', name: '水果' },
        meat: { emoji: '🥩', name: '肉类' },
        seafood: { emoji: '🐟', name: '海鲜' },
        diary: { emoji: '🥛', name: '乳制�? },
        beverage: { emoji: '🥤', name: '饮料' },
        egg: { emoji: '🥚', name: '蛋豆�? },
        bread: { emoji: '🍞', name: '面包' },
        frozen: { emoji: '🍦', name: '冷冻食品' },
        sauce: { emoji: '🍯', name: '酱料' },
        snack: { emoji: '🍿', name: '零食' },
        other: { emoji: '📦', name: '其他' }
    };
    
    const info = categoryInfo[category] || { emoji: '📦', name: '其他' };
    
    // 更新标题
    $('#currentCategoryEmoji').text(info.emoji);
    $('#currentCategoryName').text(info.name);
    $('#currentCategoryCount').text(`${filtered.length} 件`);
    
    // 隐藏网格，显示列�?
    $('#categoryGridView').hide();
    $('#categoryItemsView').show();
    
    // 渲染物品列表
    displayCategoryItems(filtered);
}

