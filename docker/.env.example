# ========================================
# 冰箱管理系统 - Docker 环境变量配置
# ========================================

# === 基础配置 ===
SERVER_NAME=localhost
# 修改为你的域名，例如：yourdomain.com 或 api.yourdomain.com

# === 功能开关 ===
ENABLE_HTTPS=false
# 是否启用 HTTPS，生产环境建议设为 true

ENABLE_FRONTEND=true
# 是否启用前端静态文件服务
# true: 提供完整的前后端服务
# false: 仅提供 API 服务（适合配合 Vercel 前端）

ENABLE_BACKEND_PORT=false
# 是否在 8080 端口提供独立的后端 API 服务
# true: 同时在 80/443 和 8080 端口提供 API
# false: 仅在 80/443 端口提供服务

# === SSL 证书配置 ===
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
# 启用 HTTPS 时需要挂载证书文件到这些路径

# === CORS 配置 ===
CORS_ORIGIN=*
# 允许跨域访问的源
# 示例：
# CORS_ORIGIN=https://your-app.vercel.app  # 仅允许 Vercel 前端
# CORS_ORIGIN=*                            # 允许所有源（开发环境）

# === 后端配置 ===
HOST=127.0.0.1
PORT=8080
DATABASE_DIR=/data
FLASK_ENV=production

# === 安全配置 ===
SECRET_KEY=your-random-secret-key-here
# 建议使用随机生成的 32 位字符串

# === AI 功能配置（可选）===
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# === 邮件配置（可选）===
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_USE_TLS=true

# ========================================
# 常见部署场景配置示例
# ========================================

# 场景 1：完整部署（前端 + 后端）
# ENABLE_FRONTEND=true
# ENABLE_BACKEND_PORT=false
# CORS_ORIGIN=*

# 场景 2：仅后端 API + HTTPS（配合 Vercel 前端）
# ENABLE_FRONTEND=false
# ENABLE_HTTPS=true
# CORS_ORIGIN=https://your-app.vercel.app

# 场景 3：仅后端 API + HTTP（配合 Vercel 前端，无证书）
# ENABLE_FRONTEND=false
# ENABLE_HTTPS=false
# CORS_ORIGIN=https://your-app.vercel.app

# 场景 4：双端口模式
# ENABLE_FRONTEND=true
# ENABLE_BACKEND_PORT=true
# CORS_ORIGIN=*

# 场景 5：HTTPS 生产环境
# SERVER_NAME=yourdomain.com
# ENABLE_HTTPS=true
# ENABLE_FRONTEND=true
# CORS_ORIGIN=https://yourdomain.com
